# EngageAI Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/EngageAI

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=engageai

# Server port
PORT=5000

# CORS — set to true to restrict allowed origins
CORS_ENABLED=false
# Comma-separated list of allowed origins (only used when CORS_ENABLED=true)
CORS_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000

# JWT secret for admin auth (change in production!)
JWT_SECRET=engageai-secret-change-me
JWT_EXPIRY_HOURS=24
